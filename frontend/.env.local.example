# --- Auth (next-auth v5 / Microsoft Entra ID) ---
AUTH_SECRET=                      # `openssl rand -base64 32`
AUTH_MICROSOFT_ENTRA_ID_ID=       # App registration client ID
AUTH_MICROSOFT_ENTRA_ID_SECRET=   # App registration client secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=common  # or your specific tenant ID

# --- API ---
NEXT_PUBLIC_API_URL=http://localhost:5001   # Backend URL

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- App URL ---
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
