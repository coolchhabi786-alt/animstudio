# ─────────────────────────────────────────────────────────────────────────────
# Frontend (Next.js / Node.js) .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
build/
dist/

# Next.js cache
.swc/

# TypeScript incremental compilation
*.tsbuildinfo
next-env.d.ts

# Environment variables — never commit real values
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing coverage
coverage/
.nyc_output/
playwright-report/
test-results/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS generated files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.idea/
*.sublime-workspace
*.sublime-project

# Vercel / deployment
.vercel

# Storybook
storybook-static/
