# Rider
.idea/
*.sln.iml

# NuGet packages (restored on build; never commit)
packages/
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# Compiled output / binaries
*.exe
*.dll
*.pdb
*.lib
*.exp
*.obj
*.iobj
*.ipdb
*.ilk
*.map
*.meta
*.so
*.dylib

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coveragexml
coverage*/
*.coverage
*.covxml

# NCrunch
*.ncrunch*

# Caches and intermediates
*.cache
*.tmp
*.bak
*.swp
*_i.c
*_p.c
*_h.h
*.ilg
*.tlog
*.lastbuildstate
.dtbcache*
*.dtbcache*

# Publish / deploy
publish/
PublishProfiles/
*.pubxml
*.pubxml.user
*.publishsettings

# Azure Pipeline / CI
*.publishsettings

# Local secrets — keep out of source control
secrets.json
appsettings.Development.json
appsettings.Production.json
appsettings.Staging.json
appsettings.*.local.json

# Certificates & private keys
*.pfx
*.p12
*.key
*.pem
*.cer

# OS generated files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Database snapshots / migration backups
*.mdf
*.ldf
