{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=AnimStudio;User Id=sa;Password=AnimStudio!Dev123;TrustServerCertificate=True;MultipleActiveResultSets=true",
    "HangfireConnection": "Server=localhost,1433;Database=AnimStudio_Hangfire;User Id=sa;Password=AnimStudio!Dev123;TrustServerCertificate=True;",
    "Redis": "localhost:6379,password=AnimRedis!Dev123"
  },
  "Auth": {
    "Authority": "https://login.microsoftonline.com/common/v2.0",
    "Audience": "api://animstudio-api"
  },
  "Azure": {
    "KeyVaultUri": ""
  },
  "AppSettings": {
    "BaseUrl": "http://localhost:3000"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "Stripe": {
    "SecretKey": "sk_test_REPLACE_WITH_YOUR_STRIPE_TEST_KEY",
    "WebhookSecret": "whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET"
  },
  "FileStorage": {
    "Provider": "AzureBlob",
    "LocalRootPath": "",
    "BackendBaseUrl": "https://api.animstudio.ai"
  },
  "AzureCommunicationServices": {
    "ConnectionString": "REPLACE_WITH_ACS_CONNECTION_STRING",
    "SenderAddress": "noreply@animstudio.ai"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": { "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
